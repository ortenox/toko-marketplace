{
    "editor.formatOnSave": true,

    "editor.defaultFormatter": "esbenp.prettier-vscode",

    "[php]": {
        "editor.defaultFormatter": "bmewburn.vscode-intelephense-client"
    },

    "[blade]": {
        "editor.defaultFormatter": "shufo.vscode-blade-formatter"
    },

    "editor.tabSize": 4,
    "editor.insertSpaces": true,

    "files.associations": {
        "*.blade.php": "blade"
    },

    "intelephense.environment.phpVersion": "8.4.0",

    "emmet.includeLanguages": {
        "blade": "html"
    },

    "phpNamespaceResolver.sortAlphabetically": true,
    "phpNamespaceResolver.autoSort": true,

    "editor.rulers": [120],

    "files.exclude": {
        "vendor/": true,
        "node_modules/": true,
        "storage/": true,
        ".git/": true
    },

    "search.exclude": {
        "vendor/**": true,
        "node_modules/**": true,
        "public/build/**": true
    }
}
